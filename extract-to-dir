#!/usr/bin/env bash
# extract-to-dir - extracts archives into their own named directories,
# preventing file sprawl in the current or source directory.
# Supports tar, zip, rar, 7z, single-file compression, iso, and cab formats.
# Requires: tar (core); unzip, unrar, 7z, cabextract as needed per format.

set -euo pipefail

VERSION="1.1"

show_help() {
    cat <<'EOF'
Usage:
  extract-to-dir [--force] [--in-place] <archive> [archive ...]

Extracts one or more archives into their own named directories,
preventing file sprawl in the working directory.

Options:
  -f, --force      Extract even if the destination directory already exists.
  -i, --in-place   Extract next to the archive file instead of in the
                   current directory.
  -h, --help       Show this help message and exit.
      --version    Show version information and exit.

Supported formats:
  tar.gz, tgz, tar.bz2, tbz2, tar.xz, txz, tar.zst, tzst, tar
  zip, rar, 7z
  gz, bz2, xz, zst, lzma, Z
  iso, cab, exe (cabinet archives)

Tool requirements by format:
  tar.*             tar (standard)
  gz/bz2/xz/zst/Z  gunzip / bunzip2 / unxz / unzstd / uncompress
  zip               unzip or 7z
  rar               unrar or 7z
  7z / iso          7z
  cab / exe         cabextract or 7z

Examples:
  extract-to-dir file.tar.gz
  extract-to-dir a.zip b.rar
  extract-to-dir --force existing.zip
  extract-to-dir --in-place downloads/archive.zip documents/archive.zip
EOF
}

# ------------------------
# Flags and argument parsing
# ------------------------
force=0
in_place=0

# Handle help and version before the main parse loop
case "${1:-}" in
    -h|--help)   show_help; exit 0 ;;
    --version)   echo "extract-to-dir version $VERSION"; exit 0 ;;
esac

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--force)    force=1;    shift ;;
        -i|--in-place) in_place=1; shift ;;
        -h|--help)     show_help;  exit 0 ;;
        --version)     echo "extract-to-dir version $VERSION"; exit 0 ;;
        --)            shift; break ;;
        -*)            echo "Unknown option: $1" >&2; show_help; exit 1 ;;
        *)             break ;;
    esac
done

if [[ $# -lt 1 ]]; then
    show_help
    exit 1
fi

# ------------------------
# Helper: check if a command exists
# ------------------------
have() { command -v "$1" >/dev/null 2>&1; }

# ------------------------
# Derive a clean destination directory name from an archive filename.
# Strips compound extensions (e.g. .tar.gz) before single ones,
# then falls back to "extracted" if stripping produces an empty string.
# ------------------------
dest_dir_for() {
    local base="$1" d
    d="$(basename "$base")"

    # Strip compound extensions first
    d="${d%.tar.gz}";  d="${d%.tgz}"
    d="${d%.tar.bz2}"; d="${d%.tbz2}"
    d="${d%.tar.xz}";  d="${d%.txz}"
    d="${d%.tar.zst}"; d="${d%.tzst}"

    # Then single extensions
    d="${d%.zip}"; d="${d%.rar}"; d="${d%.7z}"
    d="${d%.tar}"; d="${d%.gz}";  d="${d%.bz2}"; d="${d%.xz}"; d="${d%.zst}"
    d="${d%.lzma}"; d="${d%.Z}"
    d="${d%.iso}"
    d="${d%.cab}"; d="${d%.exe}"

    # Fallback if stripping produced an empty string
    [[ -n "$d" ]] || d="extracted"
    echo "$d"
}

# ------------------------
# Extract a single archive into its own named directory.
# Returns non-zero on failure; partial directories are cleaned up on error.
# ------------------------
extract_one() {
    local f="$1" base dir dest_base archive_dir

    if [[ ! -f "$f" ]]; then
        echo "extract-to-dir: '$f' - file does not exist" >&2
        return 2
    fi

    base="$(basename "$f")"
    dest_base="$(dest_dir_for "$f")"

    # Determine extraction location based on --in-place flag
    if [[ $in_place -eq 1 ]]; then
        archive_dir="$(dirname "$f")"
        # Avoid double slashes when archive is in the current directory
        if [[ "$archive_dir" == "." ]]; then
            dir="$dest_base"
        else
            dir="$archive_dir/$dest_base"
        fi
    else
        dir="$dest_base"
    fi

    # Abort early if destination exists and --force was not given
    if [[ -e "$dir" && $force -eq 0 ]]; then
        echo "extract-to-dir: destination '$dir/' already exists (use --force to extract anyway). Skipping '$base'." >&2
        return 0
    fi

    mkdir -p -- "$dir"
    echo "==> '$base' -> '$dir/'"

    case "$f" in

        # --- tar variants ---
        *.tar.bz2|*.tbz2)  tar -xjf "$f"        -C "$dir" ;;
        *.tar.gz|*.tgz)    tar -xzf "$f"        -C "$dir" ;;
        *.tar.xz|*.txz)    tar -xJf "$f"        -C "$dir" ;;
        *.tar.zst|*.tzst)  tar --zstd -xf "$f"  -C "$dir" ;;
        *.tar)             tar -xf "$f"          -C "$dir" ;;

        # --- single-file compression: decompress into the named directory ---
        *.gz)   gunzip    -c -- "$f" > "$dir/${base%.gz}"   ;;
        *.bz2)  bunzip2   -c -- "$f" > "$dir/${base%.bz2}"  ;;
        *.xz)   unxz      -c -- "$f" > "$dir/${base%.xz}"   ;;
        *.zst)  unzstd    -c -- "$f" > "$dir/${base%.zst}"  ;;
        *.Z)    uncompress -c -- "$f" > "$dir/${base%.Z}"   ;;
        *.lzma) unlzma    -c -- "$f" > "$dir/${base%.lzma}" ;;

        # --- zip: prefer unzip, fall back to 7z ---
        *.zip)
            if have unzip; then
                unzip -q -- "$f" -d "$dir"
            elif have 7z; then
                7z x -y -- "$f" -o"$dir"
            else
                echo "extract-to-dir: no zip extractor found (need unzip or 7z)" >&2
                rmdir -- "$dir" 2>/dev/null || true
                return 4
            fi
            ;;

        # --- rar: prefer unrar, fall back to 7z ---
        *.rar)
            if have unrar; then
                unrar x -ad "$f" "$dir"
            elif have 7z; then
                7z x -y -- "$f" -o"$dir"
            else
                echo "extract-to-dir: no rar extractor found (need unrar or 7z)" >&2
                rmdir -- "$dir" 2>/dev/null || true
                return 4
            fi
            ;;

        # --- 7z: requires 7z ---
        *.7z)
            if have 7z; then
                7z x -y -- "$f" -o"$dir"
            else
                echo "extract-to-dir: 7z not found" >&2
                rmdir -- "$dir" 2>/dev/null || true
                return 3
            fi
            ;;

        # --- iso: requires 7z ---
        *.iso)
            if have 7z; then
                7z x -y -- "$f" -o"$dir"
            else
                echo "extract-to-dir: 7z not found (needed for ISO)" >&2
                rmdir -- "$dir" 2>/dev/null || true
                return 3
            fi
            ;;

        # --- cab/exe cabinet archives: prefer cabextract, fall back to 7z ---
        *.cab|*.exe)
            if have cabextract; then
                cabextract -d "$dir" -- "$f"
            elif have 7z; then
                7z x -y -- "$f" -o"$dir"
            else
                echo "extract-to-dir: no CAB extractor found (need cabextract or 7z)" >&2
                rmdir -- "$dir" 2>/dev/null || true
                return 4
            fi
            ;;

        # --- unknown format: try tar, then 7z as universal fallback ---
        *)
            if tar -xf "$f" -C "$dir" 2>/dev/null; then
                : # Success with tar
            elif have 7z; then
                7z x -y -- "$f" -o"$dir"
            else
                echo "extract-to-dir: '$base' - unknown archive format, and no fallback extractor found" >&2
                rmdir -- "$dir" 2>/dev/null || true
                return 4
            fi
            ;;
    esac
}

# ------------------------
# Process each archive in turn
# ------------------------
for f in "$@"; do
    extract_one "$f"
done